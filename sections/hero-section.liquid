{%- comment -%}
  Hero section
  Flexible homepage hero: background image (desktop + optional mobile crop),
  color overlay, positionable content, repeatable text/button blocks, and
  app block support so merchants can drop app content into the hero.
{%- endcomment -%}

{%- liquid
  assign overlay_opacity = section.settings.overlay_opacity | times: 1.0 | divided_by: 100.0
-%}

{% style %}
  .hero-{{ section.id }} {
    position: relative;
    display: flex;
    overflow: hidden;
    color: {{ section.settings.text_color }};
  }
  .hero-{{ section.id }}.hero--small { min-height: 40vh; }
  .hero-{{ section.id }}.hero--medium { min-height: 60vh; }
  .hero-{{ section.id }}.hero--large { min-height: 85vh; }
  .hero-{{ section.id }}.hero--full { min-height: 100vh; }

  .hero-{{ section.id }} .hero__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .hero-{{ section.id }} .hero__media .responsive-image,
  .hero-{{ section.id }} .hero__media .responsive-image--placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .hero-{{ section.id }} .hero__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: {{ section.settings.overlay_color }};
    opacity: {{ overlay_opacity }};
    pointer-events: none;
  }
  .hero-{{ section.id }} .hero__content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;
    padding: 4rem 1.5rem;
  }
  .hero-{{ section.id }} .hero__content[data-align="left"] { align-items: flex-start; text-align: left; }
  .hero-{{ section.id }} .hero__content[data-align="center"] { align-items: center; text-align: center; }
  .hero-{{ section.id }} .hero__content[data-align="right"] { align-items: flex-end; text-align: right; }

  .hero-{{ section.id }}[data-position="top"] .hero__content { justify-content: flex-start; }
  .hero-{{ section.id }}[data-position="middle"] .hero__content { justify-content: center; }
  .hero-{{ section.id }}[data-position="bottom"] .hero__content { justify-content: flex-end; }

  .hero-{{ section.id }} .hero__heading {
    margin: 0;
    font-size: clamp(1.75rem, 5vw, 3.5rem);
    line-height: 1.1;
  }
  .hero-{{ section.id }} .hero__text {
    margin: 0;
    max-width: 40em;
    font-size: clamp(1rem, 1.6vw, 1.25rem);
  }
  .hero-{{ section.id }} .hero__buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  @media (prefers-reduced-motion: no-preference) {
    .hero-{{ section.id }} .hero__content > * {
      animation: hero-fade-up-{{ section.id }} 0.6s ease both;
    }
    @keyframes hero-fade-up-{{ section.id }} {
      from { opacity: 0; transform: translateY(12px); }
      to { opacity: 1; transform: translateY(0); }
    }
  }
{% endstyle %}

<div
  class="hero-{{ section.id }} hero--{{ section.settings.height }} color-{{ section.settings.color_scheme }}"
  data-align="{{ section.settings.text_alignment }}"
  data-position="{{ section.settings.content_position }}"
>
  <div class="hero__media">
    {% render 'responsive-image',
      image: section.settings.image,
      image_mobile: section.settings.image_mobile,
      alt: section.settings.heading,
      loading: 'eager',
      fetchpriority: 'high'
    %}
  </div>

  <div class="hero__overlay"></div>

  <div class="hero__content">
    {%- for block in section.blocks -%}
      {%- case block.type -%}

        {%- when 'heading' -%}
          <h2
            class="hero__heading"
            style="{% if block.settings.heading_size == 'small' %}font-size: clamp(1.25rem, 3.5vw, 2.25rem);{% elsif block.settings.heading_size == 'large' %}font-size: clamp(2.25rem, 6vw, 4.5rem);{% endif %}"
            {{ block.shopify_attributes }}
          >
            {{ block.settings.heading | default: section.settings.heading }}
          </h2>

        {%- when 'text' -%}
          <div class="hero__text" {{ block.shopify_attributes }}>
            {{ block.settings.text }}
          </div>

        {%- when 'buttons' -%}
          <div class="hero__buttons" {{ block.shopify_attributes }}>
            {%- if block.settings.button_label_1 != blank -%}
              {% render 'component-button',
                label: block.settings.button_label_1,
                url: block.settings.button_link_1,
                style: block.settings.button_style_1,
                size: 'large'
              %}
            {%- endif -%}
            {%- if block.settings.button_label_2 != blank -%}
              {% render 'component-button',
                label: block.settings.button_label_2,
                url: block.settings.button_link_2,
                style: block.settings.button_style_2,
                size: 'large'
              %}
            {%- endif -%}
          </div>

        {%- when '@app' -%}
          {% render block %}

      {%- endcase -%}
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Hero",
  "tag": "section",
  "class": "section-hero",
  "settings": [
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Mobile background image (optional)",
      "info": "Shown below 750px. Falls back to the main image if left blank."
    },
    {
      "type": "select",
      "id": "height",
      "label": "Section height",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" },
        { "value": "full", "label": "Full screen" }
      ],
      "default": "large"
    },
    {
      "type": "header",
      "content": "Overlay"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 90,
      "step": 5,
      "unit": "%",
      "default": 30
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "color",
      "id": "color_scheme",
      "label": "Color scheme"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#FFFFFF"
    },
    {
      "type": "select",
      "id": "content_position",
      "label": "Vertical position",
      "options": [
        { "value": "top", "label": "Top" },
        { "value": "middle", "label": "Middle" },
        { "value": "bottom", "label": "Bottom" }
      ],
      "default": "middle"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Fallback heading",
      "info": "Used as alt text and as a fallback if no heading block is added.",
      "default": "Tell your story"
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "Heading",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Tell your story"
        },
        {
          "type": "select",
          "id": "heading_size",
          "label": "Size",
          "options": [
            { "value": "small", "label": "Small" },
            { "value": "medium", "label": "Medium" },
            { "value": "large", "label": "Large" }
          ],
          "default": "medium"
        }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "limit": 1,
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Pair this with a short, confident line about your brand.</p>"
        }
      ]
    },
    {
      "type": "buttons",
      "name": "Buttons",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "button_label_1",
          "label": "First button label",
          "default": "Shop now"
        },
        {
          "type": "url",
          "id": "button_link_1",
          "label": "First button link"
        },
        {
          "type": "select",
          "id": "button_style_1",
          "label": "First button style",
          "options": [
            { "value": "primary", "label": "Primary" },
            { "value": "secondary", "label": "Secondary" }
          ],
          "default": "primary"
        },
        {
          "type": "text",
          "id": "button_label_2",
          "label": "Second button label"
        },
        {
          "type": "url",
          "id": "button_link_2",
          "label": "Second button link"
        },
        {
          "type": "select",
          "id": "button_style_2",
          "label": "Second button style",
          "options": [
            { "value": "primary", "label": "Primary" },
            { "value": "secondary", "label": "Secondary" }
          ],
          "default": "secondary"
        }
      ]
    },
    {
      "type": "@app"
    }
  ],
  "presets": [
    {
      "name": "Hero",
      "blocks": [
        { "type": "heading" },
        { "type": "text" },
        { "type": "buttons" }
      ]
    }
  ]
}
{% endschema %}
