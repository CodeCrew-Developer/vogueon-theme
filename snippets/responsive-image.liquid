{%- comment -%}
  Renders a responsive <img> with srcset/sizes, an optional mobile-specific
  source, and a graceful placeholder when no image is set.

  Accepts:
    image            {object}  required - Shopify image object
    image_mobile     {object}  optional - swapped in below `mobile_breakpoint`
    alt              {string}  optional - overrides image.alt
    mobile_breakpoint {string} optional - CSS length, default "749px"
    sizes            {string}  optional - sizes attr, default "100vw"
    widths           {string}  optional - comma list of widths to generate
    class            {string}  optional - extra classes on the <img>
    loading          {string}  optional - "lazy" (default) or "eager"
    fetchpriority    {string}  optional - "high" | "low" | "auto"

  Usage:
    {% render 'responsive-image',
      image: section.settings.image,
      image_mobile: section.settings.image_mobile,
      alt: section.settings.heading,
      sizes: '100vw',
      loading: 'eager',
      fetchpriority: 'high'
    %}
{%- endcomment -%}

{%- liquid
  assign widths = widths | default: '375,550,750,1100,1500,1780,2000,3000,3840'
  assign width_list = widths | split: ','
  assign sizes = sizes | default: '100vw'
  assign loading = loading | default: 'lazy'
  assign mobile_breakpoint = mobile_breakpoint | default: '749px'
-%}

{%- if image -%}
  <picture>
    {%- if image_mobile -%}
      <source
        media="(max-width: {{ mobile_breakpoint }})"
        srcset="
          {%- for w in width_list -%}
            {{ image_mobile | image_url: width: w }} {{ w }}w{% unless forloop.last %},{% endunless %}
          {%- endfor -%}
        "
      >
    {%- endif -%}
    <img
      src="{{ image | image_url: width: 1500 }}"
      srcset="
        {%- for w in width_list -%}
          {{ image | image_url: width: w }} {{ w }}w{% unless forloop.last %},{% endunless %}
        {%- endfor -%}
      "
      sizes="{{ sizes }}"
      alt="{{ alt | default: image.alt | escape }}"
      width="{{ image.width }}"
      height="{{ image.height }}"
      loading="{{ loading }}"
      {% if fetchpriority %}fetchpriority="{{ fetchpriority }}"{% endif %}
      class="responsive-image{% if class %} {{ class }}{% endif %}"
    >
  </picture>
{%- else -%}
  {{ 'lifestyle-1' | placeholder_svg_tag: 'responsive-image responsive-image--placeholder' }}
{%- endif -%}
